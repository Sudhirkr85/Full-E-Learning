generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String          @id @default(uuid()) @db.Uuid
  name                String?
  email               String          @unique
  phone               String?
  emailVerified       DateTime?
  image               String?
  passwordHash        String
  firstName           String?
  lastName            String?
  locale              String?
  timezone            String?
  role                UserRole        @default(STUDENT)
  isActive            Boolean         @default(true)
  lastLoginAt         DateTime?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  attempts            Attempt[]
  teachingAssignments CourseTeacher[]
  enrollments         Enrollment[]
  notifications       Notification[]
  orders              Order[]
  assignedTickets     SupportTicket[] @relation("TicketAssignee")
  supportTickets      SupportTicket[] @relation("TicketReporter")
  wishlists           Wishlist[]
  reviews             Review[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Category {
  id          String           @id @default(uuid()) @db.Uuid
  name        String
  slug        String           @unique
  description String?
  iconUrl     String?
  parentId    String?          @db.Uuid
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  parent      Category?        @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]       @relation("CategoryTree")
  courses     CourseCategory[]

  @@index([parentId])
  @@map("categories")
}

model Course {
  id                 String           @id @default(uuid()) @db.Uuid
  title              String
  slug               String           @unique
  subtitle           String?
  description        String?
  excerpt            String?
  coverImageUrl      String?
  coverImageProvider AssetProvider?
  trailerUrl         String?
  level              CourseLevel      @default(BEGINNER)
  status             CourseStatus     @default(DRAFT)
  language           String           @default("en")
  priceCents         Int              @default(0)
  currency           String           @default("USD")
  durationMinutes    Int?
  publishedAt        DateTime?
  archivedAt         DateTime?
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  categories         CourseCategory[]
  sections           CourseSection[]
  teachers           CourseTeacher[]
  enrollments        Enrollment[]
  products           Product[]
  tests              Test[]
  wishlists          Wishlist[]

  @@index([status])
  @@index([publishedAt])
  @@map("courses")
}

model CourseCategory {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @db.Uuid
  categoryId String   @db.Uuid
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, categoryId])
  @@index([courseId])
  @@index([categoryId])
  @@map("course_categories")
}

model CourseTeacher {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @db.Uuid
  teacherId  String   @db.Uuid
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  notes      String?
  assignedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher    User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([courseId, teacherId])
  @@index([courseId])
  @@index([teacherId])
  @@map("course_teachers")
}

model CourseSection {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @db.Uuid
  title       String
  slug        String
  description String?
  orderIndex  Int
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  tests       Test[]

  @@unique([courseId, slug])
  @@unique([courseId, orderIndex])
  @@index([courseId])
  @@map("course_sections")
}

model Lesson {
  id               String            @id @default(uuid()) @db.Uuid
  sectionId        String            @db.Uuid
  title            String
  slug             String
  description      String?
  orderIndex       Int
  contentType      LessonContentType @default(VIDEO)
  youtubeUrl       String?
  r2AssetUrl       String?
  thumbnailUrl     String?
  transcriptUrl    String?
  durationSeconds  Int?
  isPreview        Boolean           @default(false)
  isPublished      Boolean           @default(true)
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  scheduledAt      DateTime?
  progressMarkers  CourseProgress[]  @relation("LessonProgressMarkers")
  lessonProgresses LessonProgress[]
  resources        LessonResource[]
  section          CourseSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, slug])
  @@unique([sectionId, orderIndex])
  @@index([sectionId])
  @@map("lessons")
}

model LessonResource {
  id             String        @id @default(uuid()) @db.Uuid
  lessonId       String        @db.Uuid
  title          String
  resourceType   ResourceType
  provider       AssetProvider
  url            String
  mimeType       String?
  fileSizeBytes  Int?
  orderIndex     Int           @default(0)
  isDownloadable Boolean       @default(true)
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lesson         Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_resources")
}

model Enrollment {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  courseId         String           @db.Uuid
  status           EnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime         @default(now())
  completedAt      DateTime?
  expiresAt        DateTime?
  lastAccessedAt   DateTime?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  attempts         Attempt[]
  certificate      Certificate?
  progress         CourseProgress?
  review           CourseReview?
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonProgresses LessonProgress[]

  razorpayOrderId   String?
  razorpayPaymentId String?
  paymentStatus     String?   @default("FREE")
  amountPaid        Int?      @default(0)
  failureReason     String?
  failedAt          DateTime?
  paidAt            DateTime?
  emailSentAt       DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("enrollments")
}

model CourseProgress {
  id                    String     @id @default(uuid()) @db.Uuid
  enrollmentId          String     @unique @db.Uuid
  lastLessonId          String?    @db.Uuid
  completedLessonsCount Int        @default(0)
  totalLessonsCount     Int        @default(0)
  progressPercent       Int        @default(0)
  lastAccessedAt        DateTime?
  completedAt           DateTime?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  enrollment            Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lastLesson            Lesson?    @relation("LessonProgressMarkers", fields: [lastLessonId], references: [id])

  @@index([lastLessonId])
  @@index([progressPercent])
  @@map("course_progress")
}

model LessonProgress {
  id           String     @id @default(uuid()) @db.Uuid
  enrollmentId String     @db.Uuid
  lessonId     String     @db.Uuid
  isCompleted  Boolean    @default(false)
  completedAt  DateTime?
  lastViewedAt DateTime?
  metadata     Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
  @@index([isCompleted])
  @@map("lesson_progress")
}

model CourseReview {
  id           String       @id @default(uuid()) @db.Uuid
  enrollmentId String       @unique @db.Uuid
  rating       Int
  title        String?
  body         String?
  status       ReviewStatus @default(PUBLISHED)
  isFeatured   Boolean      @default(false)
  reviewedAt   DateTime     @default(now())
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([rating])
  @@index([status])
  @@map("course_reviews")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  courseId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("wishlists")
}

model Test {
  id               String         @id @default(uuid()) @db.Uuid
  courseId         String         @db.Uuid
  sectionId        String?        @db.Uuid
  title            String
  slug             String
  description      String?
  type             TestType       @default(QUIZ)
  passingScore     Int            @default(70)
  timeLimitMinutes Int?
  attemptLimit     Int?
  shuffleQuestions Boolean        @default(false)
  isPublished      Boolean        @default(false)
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  attempts         Attempt[]
  questions        Question[]
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section          CourseSection? @relation(fields: [sectionId], references: [id])

  @@unique([courseId, slug])
  @@index([courseId])
  @@index([sectionId])
  @@map("tests")
}

model Question {
  id          String          @id @default(uuid()) @db.Uuid
  testId      String          @db.Uuid
  prompt      String
  explanation String?
  kind        QuestionType    @default(SINGLE_CHOICE)
  orderIndex  Int
  points      Int             @default(1)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  answers     AttemptAnswer[]
  options     Option[]
  test        Test            @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, orderIndex])
  @@index([testId])
  @@map("questions")
}

model Option {
  id          String          @id @default(uuid()) @db.Uuid
  questionId  String          @db.Uuid
  label       String
  value       String?
  isCorrect   Boolean         @default(false)
  orderIndex  Int
  explanation String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  answers     AttemptAnswer[]
  question    Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, orderIndex])
  @@index([questionId])
  @@map("options")
}

model Attempt {
  id                  String          @id @default(uuid()) @db.Uuid
  testId              String          @db.Uuid
  userId              String          @db.Uuid
  enrollmentId        String?         @db.Uuid
  status              AttemptStatus   @default(IN_PROGRESS)
  attemptNumber       Int             @default(1)
  startedAt           DateTime        @default(now())
  submittedAt         DateTime?
  gradedAt            DateTime?
  scorePercent        Int?
  correctAnswersCount Int             @default(0)
  totalQuestionsCount Int             @default(0)
  timeSpentSeconds    Int?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  answers             AttemptAnswer[]
  enrollment          Enrollment?     @relation(fields: [enrollmentId], references: [id])
  test                Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId, attemptNumber])
  @@index([testId])
  @@index([userId])
  @@index([enrollmentId])
  @@index([status])
  @@map("attempts")
}

model AttemptAnswer {
  id               String    @id @default(uuid()) @db.Uuid
  attemptId        String    @db.Uuid
  questionId       String    @db.Uuid
  selectedOptionId String?   @db.Uuid
  answerText       String?
  isCorrect        Boolean?
  gradedAt         DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  attempt          Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   Option?   @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@index([selectedOptionId])
  @@map("attempt_answers")
}

model Product {
  id                 String         @id @default(uuid()) @db.Uuid
  courseId           String?        @db.Uuid
  title              String
  slug               String         @unique
  description        String?
  shortDescription   String?
  fullDescription    String?
  stockQuantity      Int?
  shippingRequired   Boolean?       @default(false)
  dispatchNotes      String?
  bundleItems        Json?
  productType        ProductType    @default(DIGITAL_RESOURCE)
  status             ProductStatus  @default(DRAFT)
  priceCents         Int            @default(0)
  originalPriceCents Int?
  currency           String         @default("USD")
  assetUrl           String?
  assetProvider      AssetProvider?
  coverImageUrl      String?
  coverImageProvider AssetProvider?
  inventoryCount     Int?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  orderItems         OrderItem[]
  course             Course?        @relation(fields: [courseId], references: [id])
  reviews            Review[]

  @@index([courseId])
  @@index([status])
  @@map("products")
}

model Coupon {
  id                      String       @id @default(uuid()) @db.Uuid
  code                    String       @unique
  name                    String
  description             String?
  couponType              CouponType   @default(PERCENTAGE)
  discountValue           Int
  minimumOrderAmountCents Int?
  maxDiscountCents        Int?
  maxRedemptions          Int?         // maps to global usage limit
  perUserLimit            Int?         @default(1)
  redeemedCount           Int          @default(0)
  startsAt                DateTime?
  endsAt                  DateTime?
  isActive                Boolean      @default(true)
  appliesTo               String       @default("ALL") // ALL, STORE, COURSES, DIGITAL_PRODUCTS, PHYSICAL_PRODUCTS, SPECIFIC_PRODUCTS, SPECIFIC_COURSES
  appliesToIds            String[]     @default([])    // Specific course / product UUID list string array
  metadata                Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  orders                  Order[]
  usages                  CouponUsage[]

  @@index([isActive])
  @@map("coupons")
}

model CouponUsage {
  id           String     @id @default(uuid()) @db.Uuid
  couponId     String     @db.Uuid
  userId       String     @db.Uuid
  orderId      String?    @db.Uuid
  enrollmentId String?    @db.Uuid
  discountCents Int       @default(0)
  usedAt       DateTime   @default(now())

  coupon       Coupon     @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@map("coupon_usages")
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  orderNumber   String      @unique
  userId        String?     @db.Uuid
  couponId      String?     @db.Uuid
  billingEmail  String
  status        OrderStatus @default(PENDING)
  subtotalCents Int         @default(0)
  discountCents Int         @default(0)
  taxCents      Int         @default(0)
  totalCents    Int         @default(0)
  currency      String      @default("USD")
  notes         String?
  metadata      Json?
  placedAt      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  coupon        Coupon?     @relation(fields: [couponId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
  payments      Payment[]

  failureReason  String?
  failedAt       DateTime?
  emailSentAt    DateTime?
  paidAt         DateTime?
  billingPhone   String?
  orderNotes     String?
  discount       Int       @default(0)
  subtotal       Int       @default(0)

  courierName    String?
  trackingNumber String?
  shippingStatus ShippingStatus @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?

  @@index([userId])
  @@index([couponId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              String       @id @default(uuid()) @db.Uuid
  orderId         String       @db.Uuid
  productId       String?      @db.Uuid
  productName     String
  productSlug     String?
  productType     ProductType?
  quantity        Int          @default(1)
  unitPriceCents  Int
  totalPriceCents Int
  currency        String       @default("USD")
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?     @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                String          @id @default(uuid()) @db.Uuid
  orderId           String          @db.Uuid
  provider          PaymentProvider @default(MANUAL)
  providerPaymentId String?         @unique
  status            PaymentStatus   @default(PENDING)
  amountCents       Int
  currency          String          @default("USD")
  paidAt            DateTime?
  refundedAt        DateTime?
  failureReason     String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  type      NotificationType    @default(SYSTEM)
  channel   NotificationChannel @default(IN_APP)
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  sentAt    DateTime?
  metadata  Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@map("notifications")
}

model SupportTicket {
  id           String         @id @default(uuid()) @db.Uuid
  reporterId   String         @db.Uuid
  assignedToId String?        @db.Uuid
  subject      String
  message      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String?
  resolvedAt   DateTime?
  closedAt     DateTime?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  reporter     User           @relation("TicketReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([assignedToId])
  @@index([status])
  @@map("support_tickets")
}

model Certificate {
  id               String     @id @default(uuid()) @db.Uuid
  enrollmentId     String     @unique @db.Uuid
  verificationCode String     @unique
  certificateUrl   String?
  pdfUrl           String?
  scorePercent     Int?
  issuedAt         DateTime   @default(now())
  expiresAt        DateTime?
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([issuedAt])
  @@map("certificates")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum AssetProvider {
  YOUTUBE
  CLOUDFLARE_R2
  EXTERNAL
}

enum LessonContentType {
  VIDEO
  ARTICLE
  RESOURCE
  QUIZ
  LIVE
}

enum ResourceType {
  VIDEO
  PDF
  IMAGE
  FILE
  LINK
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  PENDING
  FAILED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum TestType {
  QUIZ
  PRACTICE
  EXAM
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  ABANDONED
}

enum ProductType {
  COURSE_ACCESS
  DIGITAL_RESOURCE
  BUNDLE
  MEMBERSHIP
  PHYSICAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  PUBLISHED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  PAYPAL
}

enum NotificationType {
  SYSTEM
  COURSE
  ORDER
  SUPPORT
  CERTIFICATE
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_items")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  userId    String   @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

